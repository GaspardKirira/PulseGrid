# ----------------------------------
# Server
# ----------------------------------
SERVER_PORT=8080

# ----------------------------------
# Database (default: SQLite)
# ----------------------------------
DATABASE_ENGINE=sqlite

# SQLite
DATABASE_SQLITE_PATH=storage/pulsegrid.db

# MySQL (only used if DATABASE_ENGINE=mysql)
DATABASE_DEFAULT_HOST=127.0.0.1
DATABASE_DEFAULT_PORT=3306
DATABASE_DEFAULT_USER=root
DATABASE_DEFAULT_PASSWORD=
DATABASE_DEFAULT_NAME=appdb

# Pool
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=4

# Migrations
DATABASE_MIGRATIONS_DIR=migrations

# ----------------------------------
# Logging
# ----------------------------------
LOGGING_ASYNC=true
LOGGING_LEVEL=info

# ----------------------------------
# Security / WAF
# ----------------------------------
WAF_MODE=basic

